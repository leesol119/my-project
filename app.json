{
  "name": "eripotter",
  "description": "EriPotter - 마이크로서비스 아키텍처 프로젝트",
  "repository": "https://github.com/your-username/eripotter",
  "keywords": ["nextjs", "fastapi", "microservices", "docker"],
  "env": {
    "NODE_ENV": {
      "description": "Node.js 환경 설정",

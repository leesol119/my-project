{
  "deployment": {
    "platform": "railway",
    "frontend": {
      "framework": "nextjs",
      "buildCommand": "cd frontend && npm run build",
      "startCommand": "cd frontend && npm start",
      "outputDirectory": "frontend/.next"
    },
    "backend": {
      "framework": "fastapi",
      "buildCommand": "cd gateway && pip install -r requirements.txt",
      "startCommand": "cd gateway && uvicorn app.main:app --host 0.0.0.0 --port $PORT"
    }
  },
  "environment": {
    "NODE_ENV": "production",
    "NEXT_PUBLIC_API_URL": "https://eripotter-gateway.railway.app"
  }
} 